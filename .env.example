# ============================================================
# AbaqusGPT LLM Configuration / 大模型配置
# ============================================================

# Default LLM model / 默认模型
# Options: gpt-4o, claude-3-opus, glm-4, qwen-max, deepseek-chat, etc.
DEFAULT_MODEL=gpt-4o

# ============================================================
# International Providers / 国际模型
# ============================================================

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Ollama (Local models / 本地模型)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# Chinese LLM Providers / 国产大模型
# ============================================================

# 1. 智谱 AI (Zhipu AI / GLM)
# Models: glm-4, glm-4v, glm-3-turbo
# API Docs: https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key

# 2. 通义千问 (Qwen / Alibaba DashScope)
# Models: qwen-max, qwen-plus, qwen-turbo, qwen-vl-max
# API Docs: https://dashscope.aliyuncs.com/
DASHSCOPE_API_KEY=your-dashscope-api-key

# 3. DeepSeek
# Models: deepseek-chat, deepseek-coder
# API Docs: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key

# 4. 百度文心一言 (Wenxin / ERNIE)
# Models: ernie-4.0, ernie-3.5-turbo
# API Docs: https://cloud.baidu.com/doc/WENXINWORKSHOP/
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key

# 5. 讯飞星火 (iFlytek Spark)
# Models: spark-3.5, spark-pro
# API Docs: https://www.xfyun.cn/doc/spark/
SPARK_APP_ID=your-spark-app-id
SPARK_API_KEY=your-spark-api-key
SPARK_API_SECRET=your-spark-api-secret

# 6. 月之暗面 Kimi (Moonshot)
# Models: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
# API Docs: https://platform.moonshot.cn/
MOONSHOT_API_KEY=your-moonshot-api-key

# 7. MiniMax
# Models: abab6.5-chat, abab5.5-chat
# API Docs: https://www.minimaxi.com/
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id

# 8. 零一万物 (Yi / 01.AI)
# Models: yi-large, yi-medium, yi-spark
# API Docs: https://platform.lingyiwanwu.com/
YI_API_KEY=your-yi-api-key

# 9. 百川智能 (Baichuan)
# Models: baichuan4, baichuan3-turbo
# API Docs: https://platform.baichuan-ai.com/
BAICHUAN_API_KEY=your-baichuan-api-key

# 10. 阶跃星辰 (StepFun)
# Models: step-1-8k, step-1-32k, step-1v-8k
# API Docs: https://platform.stepfun.com/
STEPFUN_API_KEY=your-stepfun-api-key

# 11. 字节豆包 (Doubao / Volcengine)
# Models: doubao-pro-4k, doubao-lite-4k
# API Docs: https://www.volcengine.com/docs/82379
VOLCENGINE_API_KEY=your-volcengine-api-key
VOLCENGINE_ENDPOINT_ID=your-volcengine-endpoint-id

# 12. 腾讯混元 (Tencent Hunyuan)
# Models: hunyuan-pro, hunyuan-standard
# API Docs: https://cloud.tencent.com/document/product/1729
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key

# 13. 商汤日日新 (SenseNova)
# Models: nova-ptc-xl-v1
# API Docs: https://platform.sensenova.cn/
SENSENOVA_API_KEY=your-sensenova-api-key

# 14. 昆仑万维天工 (SkyWork)
# Models: skychat-megaverse
# API Docs: https://model-platform.tiangong.cn/
SKYWORK_API_KEY=your-skywork-api-key

# 15. 硅基流动 (SiliconFlow)
# Models: Aggregated models (DeepSeek, Qwen, GLM, etc.)
# API Docs: https://siliconflow.cn/
SILICONFLOW_API_KEY=your-siliconflow-api-key

# ============================================================
# Advanced Settings / 高级设置
# ============================================================

# API Proxy (for users behind firewall / 代理设置)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# Request timeout in seconds / 请求超时(秒)
LLM_TIMEOUT=60

# Temperature (0.0-1.0) / 温度参数
LLM_TEMPERATURE=0.1

# Max retries / 最大重试次数
LLM_MAX_RETRIES=3
